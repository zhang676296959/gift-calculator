generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Molly = the host user
model User {
  id               String   @id @default(cuid())
  name             String?
  email            String?  @unique
  emailVerified    DateTime?
  image            String?
  stripeCustomerId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  events   Event[]
  accounts Account[]
  sessions Session[]
  payments Payment[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// A birthday/gift event created by a host user
model Event {
  id         String   @id @default(cuid())
  userId     String
  slug       String   @unique
  title      String
  themeColor String   @default("#FF1A6C")
  isPaid     Boolean  @default(false)
  paidAt     DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions Question[]
  tiers     Tier[]
  friends   Friend[]
  payments  Payment[]
}

/// Questions in the quiz
model Question {
  id      String @id @default(cuid())
  eventId String
  order   Int
  type    String // "closeness" | "annoyance" | "budget" | "custom"
  title   String
  // JSON: [{"label":"Best friend","value":"best_friend"},...]
  options String @default("[]")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, order])
}

/// Budget tiers
model Tier {
  id      String @id @default(cuid())
  eventId String
  key     String
  label   String
  emoji   String
  verdict String
  order   Int

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  gifts Gift[]

  @@unique([eventId, key])
  @@index([eventId, order])
}

/// Gifts within a tier
model Gift {
  id     String @id @default(cuid())
  tierId String
  name   String
  order  Int

  tier       Tier            @relation(fields: [tierId], references: [id], onDelete: Cascade)
  selections GiftSelection[]

  @@index([tierId, order])
}

/// Friend who took the quiz
model Friend {
  id              String   @id @default(cuid())
  eventId         String
  name            String?  // null if anonymous
  isAnonymous     Boolean  @default(false)
  message         String?  // optional message to host
  selectedTierKey String
  createdAt       DateTime @default(now())
  // Quiz answers JSON: {"closeness":"best_friend","annoyance":"a_little"}
  answers         String   @default("{}")

  event      Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  selections GiftSelection[]

  @@index([eventId])
}

/// 1-3 gifts the friend selected
model GiftSelection {
  id       String @id @default(cuid())
  friendId String
  giftId   String

  friend Friend @relation(fields: [friendId], references: [id], onDelete: Cascade)
  gift   Gift   @relation(fields: [giftId], references: [id], onDelete: Cascade)

  @@unique([friendId, giftId])
}

/// Payment records
model Payment {
  id                    String   @id @default(cuid())
  userId                String
  eventId               String
  stripePaymentIntentId String?  @unique
  amount                Int      // cents ($4.99 = 499)
  status                String   // "pending" | "completed" | "refunded"
  createdAt             DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([eventId])
}
